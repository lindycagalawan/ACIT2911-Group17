<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log Adventure | ExploreBC</title>
    <!-- Referencing your existing styles -->
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/styles-activities.css">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&display=swap" rel="stylesheet">
</head>
<body id="destinations-page">
    <!-- Navbar -->
    <header class="navbar">
        <h1 class="logo"><a href="/" class="n">ExploreBC</a></h1>
        <nav class="nav-links">
            <ul class="lp">
                <li><a href="/" class="n">Home</a></li>
                <li><a href="/destinations" class="n">Destinations</a></li>
                <li><a href="/activities" class="n">Activities</a></li>
                <li><a href="/food" class="n">Food & Restaurants</a></li>
                <li><a href="/contact" class="n">Contact</a></li>
                <li><a href="/login" class="n">Login</a></li>
                <!-- Safeguard for user variable -->
                <% if (typeof user !== 'undefined' && user) { %>
                    <li><a href="/auth/logout" class="n">Logout</a></li>
                <% } else { %>
                    <li><a href="/auth/login" class="n">Login</a></li>
                <% } %>
            </ul>    
        </nav>
    </header>

    <main class="contact-page">
        <div class="contact-container" style="max-width: 700px; margin: 40px auto; background: white; padding: 40px; border-radius: 14px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
            <h1 style="font-family: 'Dancing Script', cursive; font-size: 3rem; text-align: center; color: #2e6b3d;">Log Your Activity</h1>
            <p style="text-align: center; margin-bottom: 30px; color: #666;">Share your trail or water experience with the community.</p>

            <form action="/activities/create" method="POST" class="contact-form">
                
                <label for="title" style="font-weight: bold; display: block; margin-bottom: 5px;">Activity Title</label>
                <input type="text" id="title" name="title" placeholder="e.g., Morning Paddle at Deep Cove" required style="width: 100%; padding: 12px; margin-bottom: 20px; border: 1px solid #ccc; border-radius: 6px;">

                <label for="type" style="font-weight: bold; display: block; margin-bottom: 5px;">Activity Type</label>
                <select name="type" id="type" style="width: 100%; padding: 12px; margin-bottom: 20px; border: 1px solid #ccc; border-radius: 6px; font-size: 1rem;">
                    <option value="Hiking">Hiking</option>
                    <option value="Biking">Biking</option>
                    <option value="Boating">Boating</option>
                    <option value="Swimming">Swimming</option>
                    <option value="Other">Other Adventure</option>
                </select>

                <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                    <div style="flex: 1;">
                        <label for="difficulty" style="font-weight: bold; display: block; margin-bottom: 5px;">Difficulty (1-5)</label>
                        <input type="number" id="difficulty" name="difficulty" min="1" max="5" placeholder="3" required style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 6px;">
                    </div>
                    <div style="flex: 1;">
                        <label for="rating" style="font-weight: bold; display: block; margin-bottom: 5px;">Experience (1-5 Stars)</label>
                        <input type="number" id="rating" name="rating" min="1" max="5" placeholder="5" required style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 6px;">
                    </div>
                </div>

                <label for="image" style="font-weight: bold; display: block; margin-bottom: 5px;">Image URL (Optional)</label>
                <input type="text" id="image" name="image" placeholder="Leave blank for default image" style="width: 100%; padding: 12px; margin-bottom: 20px; border: 1px solid #ccc; border-radius: 6px;">

                <label for="description" style="font-weight: bold; display: block; margin-bottom: 5px;">Tell us about it</label>
                <textarea id="description" name="description" rows="5" placeholder="Describe the conditions, the view, and any tips..." required style="width: 100%; padding: 12px; margin-bottom: 20px; border: 1px solid #ccc; border-radius: 6px;"></textarea>

                <button type="submit" style="width: 100%; background: #f28c38; color: white; padding: 15px; border: none; border-radius: 6px; font-weight: bold; font-size: 1.1rem; cursor: pointer; transition: background 0.3s;">Post Activity</button>
                
                <a href="/activities" style="text-align: center; display: block; margin-top: 15px; color: #2e6b3d; text-decoration: none; font-weight: bold;">Cancel and Go Back</a>
            </form>
        </div>
    </main>

    <footer class="footer">
        <a href="#" class="totem">
            <img src="/images/totem_pole.png" alt="totem pole" class="totem_pole">
        </a>
        <p>&copy; 2026 ExploreBC. All rights reserved.</p>
    </footer>
</body>
</html>