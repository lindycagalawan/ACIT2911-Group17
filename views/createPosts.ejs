<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css" />
    <link href="/css/style.css" rel="stylesheet" />
    <title>CreatePost</title>
  </head>
  <body>
    <%- include('partials/header', { user }) %>
    <main>
      <div class="authOptions">
        <h1>Create Post</h1>
        <a role="button" href="/posts">Home</a>
      </div>

      <% if (typeof error !== 'undefined') { %>
        <p style="color: red;"><%= error %></p>
      <% } %>

      <form action="/posts/create" method="POST">

        <label for="title">Title</label>
        <input type="text" name="title" id="title" placeholder="Post title" required />

        <label for="subgroup">Subgroup</label>
        <input type="text" name="subgroup" id="subgroup" placeholder="e.g. coding, food, news" required />

        <label for="link">Link</label>
        <input type="text" name="link" id="link" placeholder="https://..." />

        <label for="description">Description</label>
        <textarea name="description" id="description" placeholder="What's this post about?"></textarea>

        <small>You must provide at least a link or a description.</small>

        <button type="submit">Create Post</button>
      </form>
    </main>
  </body>
</html>