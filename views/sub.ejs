<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link rel="stylesheet" href="/css/style.css">
    <title>Sub posts</title>
  </head>
  <body>
    <%- include('partials/header', { user }) %>
    <main>
      <div class="authOptions">
        <h1>Sub Posts</h1>
        
      </div>

      <div>
        <h2 style="margin-top: 20px;">Subgroup: <%= subname %></h2>

        <% if (posts.length === 0) { %>
          <p>No posts found in this subgroup.</p>
        <% } else { %>

          <% posts.forEach(post => { %>
            <article style="margin-top: 20px; padding: 15px; border-radius: 10px; background: rgba(255,255,255,0.03);">

              <!-- Title -->
              <h3 style="margin-bottom: 5px;">
                <a href="/posts/show/<%= post.id %>">
                  <%= post.title %>
                </a>
              </h3>

              <!-- Description -->
              <p style="margin-bottom: 8px;">
                <%= post.description %>
              </p>

              <!-- Meta -->
              <small style="opacity: 0.7;">
                Posted by: 
                <%= typeof post.creator === 'object' ? post.creator.uname : "User " + post.creator %> 
                | Sub: <%= post.subgroup %>
              </small>

            </article>
          <% }) %>

        <% } %>
      </div>
    </main>
  </body>
</html>