<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css" />
    <link rel="stylesheet" href="/css/style.css">
    <title>Homepage</title>
  </head>
  <body>
    <%- include('partials/header', { user }) %>

    <main>
      <div class="authOptions">
        <h1>Homepage</h1>
      </div>

      <h2>Welcome, <%= user?.uname || "Visitor" %></h2>

      <div class="posts-section">
        <p><strong>All Posts</strong></p>

        <% posts.forEach(post => { %>
          <div class="individualPost">

            <% 
              let total = 0; 
              let userVote = 0; 

              if (post.votes) {
                post.votes.forEach(v => {
                  const val = Number(v.value) || 0;
                  total += val;

                  if (user && Number(v.user_id) === Number(user.id)) {
                    userVote = val;
                  }
                });
              }
            %>

            <!-- Title + Description -->
            <h3 style="margin: 0;">
              <a href="/posts/show/<%= post.id %>"><%= post.title %></a>
            </h3>
            <p style="margin: 0;"><%= post.description %></p>

            <!-- Votes (same style as individual post) -->
            <div class="post-meta">

              <% if (user) { %>
                <form method="POST" action="/posts/vote/<%= post.id %>" class="inline-form">
                  <input type="hidden" name="setvoteto" value="1">
                  <input type="submit" value="⬆" 
                    class="vote-arrow vote-up <%= userVote === 1 ? 'up-active' : '' %>">
                </form>
              <% } %>

              <span class="vote-number"><%= total %></span>

              <% if (user) { %>
                <form method="POST" action="/posts/vote/<%= post.id %>" class="inline-form">
                  <input type="hidden" name="setvoteto" value="-1">
                  <input type="submit" value="⬇" 
                    class="vote-arrow vote-down <%= userVote === -1 ? 'down-active' : '' %>">
                </form>
              <% } %>

              <small style="margin-left: 5px;">
                Posted by <strong><%= post.creator.uname %></strong> 
                on <%= new Date(post.timestamp).toLocaleString() %>
                in <a href="/subs/show/<%= post.subgroup %>">/s/<%= post.subgroup %></a>
              </small>

            </div>

          </div>
        <% }) %>

      </div>

      <div style="margin-top: 2rem;">
        <a href="/subs/list">Browse Subgroups</a>
        <% if (user) { %>
          | <a role="button" href="/posts/create">Create Post</a>
        <% } %>
      </div>

    </main>
  </body>
</html>