<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link rel="stylesheet" href="/css/style.css">
    <title>Confirm Delete</title>
  </head>
  <body>
    <main>
      <article>
        <h1>Confirm Deletion</h1>
        <p>Are you sure you want to delete this post?</p>
        
        <blockquote>
          <strong><%= post.title %></strong>
        </blockquote>

        <div style="display: flex; gap: 1rem; align-items: center;">
          <form action="/posts/delete/<%= post.id %>" method="POST" style="margin-bottom: 0; flex: 1;">
            <button type="submit" style="width: 100%; margin-bottom: 0;">
              Yes, Delete Post
            </button>
          </form>

          <a href="/posts/show/<%= post.id %>" role="button" class="secondary" style="flex: 1; text-align: center;">
            Cancel
          </a>
        </div>
      </article>
    </main>
  </body>
</html>