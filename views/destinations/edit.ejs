<%- include('../partials/header', { pageTitle: 'Edit Destination' }) %>

<main>
  <h1>Edit Destination</h1>
  
  <form action="/destinations/<%= destination.id %>?_method=PUT" method="POST">
    <div class="form-group">
      <label for="name">Destination Name:</label>
      <input type="text" id="name" name="name" value="<%= destination.name %>" required>
    </div>
    
    <div class="form-group">
      <label for="description">Description:</label>
      <textarea id="description" name="description" rows="5" required><%= destination.description %></textarea>
    </div>
    
    <button type="submit" class="btn">Update Destination</button>
    <a href="/destinations" class="btn btn-cancel">Cancel</a>
  </form>
</main>

<%- include('../partials/footer') %>
