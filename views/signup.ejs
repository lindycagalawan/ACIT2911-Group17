<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css" />
    <link href="/css/style.css" rel="stylesheet" />
    <title>Sign Up</title>
</head>
<body>
    <%- include('partials/header', { user }) %>
    <main class="container">
        <article style="max-width: 500px; margin: auto;">
            <header><strong>Create an Account</strong></header>
            
            <% if (error) { %>
                <p style="color: #ff4444;"><%= error %></p>
            <% } %>

            <form action="/auth/signup" method="POST">
                <label>Username</label>
                <input type="text" name="uname" placeholder="Pick a username" required>
                
                <label>Password</label>
                <input type="password" name="password" placeholder="Create a password" required>
                
                <button type="submit">Sign Up</button>
            </form>
            <footer>
                <a href="/auth/login">Already have an account? Login here.</a>
            </footer>
        </article>
    </main>
</body>
</html>